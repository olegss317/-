<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>贪吃蛇 Pro - 极致体验</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div class="game-container">
        <h1>贪吃蛇 <span class="pro-tag">PRO</span></h1>
        
        <div class="score-board">
            <div class="score-item">
                <span class="label">当前分数</span>
                <span id="score" class="value">0</span>
            </div>
            <div class="score-item">
                <span class="label">最高记录</span>
                <span id="high-score" class="value">0</span>
            </div>
        </div>

        <div class="canvas-wrapper">
            <canvas id="gameCanvas" width="400" height="400"></canvas>
            <div id="game-over-overlay" class="overlay hidden">
                <h2>游戏结束</h2>
                <p>最终得分: <span id="final-score">0</span></p>
                <button id="restart-btn-overlay">再玩一次</button>
            </div>
        </div>

        <div class="action-bar">
            <button id="start-btn">开始游戏</button>
            <button id="pause-btn" disabled>暂停</button>
        </div>

        <div class="mobile-controls">
            <div class="control-row">
                <button class="arrow-btn" id="up-btn">▲</button>
            </div>
            <div class="control-row">
                <button class="arrow-btn" id="left-btn">◀</button>
                <button class="arrow-btn" id="down-btn">▼</button>
                <button class="arrow-btn" id="right-btn">▶</button>
            </div>
        </div>

<p class="instructions">电脑端：方向键或WASD | 移动端：点击屏幕按钮</p>
    </div>
    <script src="script.js"></script>
</body>
</html>

const canvas = document.getElementById("gameCanvas");
const ctx = canvas.getContext("2d");
const scoreElement = document.getElementById("score");
const highScoreElement = document.getElementById("high-score");
const finalScoreElement = document.getElementById("final-score");
const startBtn = document.getElementById("start-btn");
const pauseBtn = document.getElementById("pause-btn");
const gameOverOverlay = document.getElementById("game-over-overlay");
const restartBtnOverlay = document.getElementById("restart-btn-overlay");

// 移动端按钮
const upBtn = document.getElementById("up-btn");
const downBtn = document.getElementById("down-btn");
const leftBtn = document.getElementById("left-btn");
const rightBtn = document.getElementById("right-btn");

const boxSize = 20;
let snake = [];
let food = {};
let score = 0;
let highScore = localStorage.getItem("highScorePro") || 0;
let d;
let gameLoop;
let isPaused = false;
let gameStarted = false;
let speed = 150; // 初始速度（毫秒）

highScoreElement.innerHTML = highScore;

// 监听键盘
document.addEventListener("keydown", (e) => {
    const key = e.key.toLowerCase();
    if ((key === "arrowleft" || key === "a") && d !== "RIGHT") d = "LEFT";
    else if ((key === "arrowup" || key === "w") && d !== "DOWN") d = "UP";
    else if ((key === "arrowright" || key === "d") && d !== "LEFT") d = "RIGHT";
    else if ((key === "arrowdown" || key === "s") && d !== "UP") d = "DOWN";
    else if (key === " ") togglePause(); // 空格键暂停
});

// 监听移动端按钮
upBtn.onclick = () => { if (d !== "DOWN") d = "UP"; };
downBtn.onclick = () => { if (d !== "UP") d = "DOWN"; };
leftBtn.onclick = () => { if (d !== "RIGHT") d = "LEFT"; };
rightBtn.onclick = () => { if (d !== "LEFT") d = "RIGHT"; };

function createFood() {
    let newFood;
    while (true) {
        newFood = {
            x: Math.floor(Math.random() * (canvas.width / boxSize)) * boxSize,
            y: Math.floor(Math.random() * (canvas.height / boxSize)) * boxSize
        };
        // 确保食物不在蛇身上
        let onSnake = snake.some(segment => segment.x === newFood.x && segment.y === newFood.y);
        if (!onSnake) break;
    }
    return newFood;
}

function initGame() {
    snake = [
        { x: 10 * boxSize, y: 10 * boxSize },
        { x: 9 * boxSize, y: 10 * boxSize },
        { x: 8 * boxSize, y: 10 * boxSize }
    ];
    food = createFood();
    score = 0;
    d = "RIGHT";
    speed = 150;
    isPaused = false;
    gameStarted = true;
    
    scoreElement.innerHTML = score;
    gameOverOverlay.classList.add("hidden");
    startBtn.disabled = true;
    pauseBtn.disabled = false;
    pauseBtn.innerHTML = "暂停";
    
    if (gameLoop) clearTimeout(gameLoop);
    draw();
}

function togglePause() {
    if (!gameStarted) return;
    isPaused = !isPaused;
    pauseBtn.innerHTML = isPaused ? "继续" : "暂停";
    if (!isPaused) draw();
}

function draw() {
    if (isPaused || !gameStarted) return;

    // 清空背景
    ctx.fillStyle = "#000";
    ctx.fillRect(0, 0, canvas.width, canvas.height);

    // 绘制网格（可选，增加科技感）
    ctx.strokeStyle = "rgba(255, 255, 255, 0.05)";
    for (let i = 0; i < canvas.width; i += boxSize) {
        ctx.beginPath(); ctx.moveTo(i, 0); ctx.lineTo(i, canvas.height); ctx.stroke();
        ctx.beginPath(); ctx.moveTo(0, i); ctx.lineTo(canvas.width, i); ctx.stroke();
    }

    // 绘制蛇
    snake.forEach((segment, index) => {
        const isHead = index === 0;
        ctx.fillStyle = isHead ? "#2ecc71" : "#27ae60";
        
        // 绘制圆角矩形
        const r = 4; // 圆角半径
        ctx.beginPath();
        ctx.roundRect(segment.x + 1, segment.y + 1, boxSize - 2, boxSize - 2, r);
        ctx.fill();

        if (isHead) {
            // 画眼睛
            ctx.fillStyle = "white";
            let eyeX1, eyeY1, eyeX2, eyeY2;
            if (d === "RIGHT") { eyeX1 = 14; eyeY1 = 5; eyeX2 = 14; eyeY2 = 12; }
            else if (d === "LEFT") { eyeX1 = 2; eyeY1 = 5; eyeX2 = 2; eyeY2 = 12; }
            else if (d === "UP") { eyeX1 = 5; eyeY1 = 2; eyeX2 = 12; eyeY2 = 2; }
            else { eyeX1 = 5; eyeY1 = 14; eyeX2 = 12; eyeY2 = 14; }
            ctx.fillRect(segment.x + eyeX1, segment.y + eyeY1, 4, 4);
            ctx.fillRect(segment.x + eyeX2, segment.y + eyeY2, 4, 4);
        }
    });

    // 绘制食物
    ctx.fillStyle = "#e74c3c";
    ctx.beginPath();
    ctx.arc(food.x + boxSize/2, food.y + boxSize/2, boxSize/2 - 2, 0, Math.PI * 2);
    ctx.fill();
    // 食物光晕
    ctx.shadowBlur = 10;
    ctx.shadowColor = "#e74c3c";
    ctx.fill();
    ctx.shadowBlur = 0;

    // 获取旧蛇头位置
    let headX = snake[0].x;
    let headY = snake[0].y;

    if (d === "LEFT") headX -= boxSize;
    if (d === "UP") headY -= boxSize;
    if (d === "RIGHT") headX += boxSize;
    if (d === "DOWN") headY += boxSize;

    // 吃到食物
    if (headX === food.x && headY === food.y) {
        score++;
        scoreElement.innerHTML = score;
        food = createFood();
        // 增加难度：每吃 5 个食物提速
        if (score % 5 === 0 && speed > 60) {
            speed -= 10;
        }
    } else {
        snake.pop();
    }

    const newHead = { x: headX, y: headY };

    // 游戏结束
    if (headX < 0 || headX >= canvas.width || headY < 0 || headY >= canvas.height || 
        snake.some(segment => segment.x === newHead.x && segment.y === newHead.y)) {
        gameOver();
        return;
    }

    snake.unshift(newHead);
    gameLoop = setTimeout(draw, speed);
}

function gameOver() {
    gameStarted = false;
    pauseBtn.disabled = true;
    startBtn.disabled = false;
    finalScoreElement.innerHTML = score;
    gameOverOverlay.classList.remove("hidden");
    
    if (score > highScore) {
        highScore = score;
        localStorage.setItem("highScorePro", highScore);
        highScoreElement.innerHTML = highScore;
    }
}

startBtn.onclick = initGame;
restartBtnOverlay.onclick = initGame;
pauseBtn.onclick = togglePause;

// 初始绘制一个背景
ctx.fillStyle = "#000";
ctx.fillRect(0, 0, canvas.width, canvas.height);

:root {
    --primary-color: #2ecc71;
    --secondary-color: #27ae60;
    --bg-color: #1a1a1a;
    --card-bg: #2c3e50;
    --text-color: #ecf0f1;
    --food-color: #e74c3c;
    --overlay-bg: rgba(0, 0, 0, 0.85);
}

* {
    box-sizing: border-box;
    -webkit-tap-highlight-color: transparent;
}

body {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100vh;
    margin: 0;
    background-color: var(--bg-color);
    color: var(--text-color);
    font-family: 'PingFang SC', 'Microsoft YaHei', sans-serif;
}

.game-container {
    width: 95%;
    max-width: 450px;
    text-align: center;
    background-color: var(--card-bg);
    padding: 20px;
    border-radius: 20px;
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.6);
}

h1 {
    margin: 0 0 20px 0;
    font-size: 1.8rem;
    letter-spacing: 2px;
}

.pro-tag {
    font-size: 0.8rem;
    background: var(--primary-color);
    padding: 2px 6px;
    border-radius: 4px;
    vertical-align: middle;
}

.score-board {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 15px;
    margin-bottom: 20px;
}

.score-item {
    background: rgba(0, 0, 0, 0.3);
    padding: 10px;
    border-radius: 12px;
}

.label {
    display: block;
    font-size: 0.8rem;
    color: #bdc3c7;
}

.value {
    font-size: 1.4rem;
    font-weight: bold;
    color: var(--primary-color);
}

.canvas-wrapper {
    position: relative;
    width: 100%;
    max-width: 400px;
    margin: 0 auto;
}

#gameCanvas {
    width: 100%;
    height: auto;
    background-color: #000;
    border: 4px solid #34495e;
    border-radius: 8px;
    display: block;
}

.overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: var(--overlay-bg);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    border-radius: 8px;
    z-index: 10;
    transition: opacity 0.3s ease;
}

.hidden {
    display: none;
    opacity: 0;
}

.action-bar {
    display: flex;
    gap: 10px;
    justify-content: center;
    margin: 20px 0;
}

button {
    padding: 12px 24px;
    font-size: 1rem;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    font-weight: bold;
    transition: all 0.2s ease;
}

#start-btn, #restart-btn-overlay {
    background: var(--primary-color);
    color: white;
}

#pause-btn {
    background: #f1c40f;
    color: #000;
}

button:active {
    transform: scale(0.95);
}

button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}

.mobile-controls {
显示：无；
    flex-direction: column;
    align-items: center;
    gap: 10px;
    margin-top: 20px;
}

.control-row {
    display: flex;
    gap: 10px;
}

.arrow-btn {
    width: 60px;
    height: 60px;
    padding: 0;
    background: rgba(255, 255, 255, 0.1);
    color: white;
    font-size: 1.5rem;
    border: 1px solid rgba(255, 255, 255, 0.2);
}

.instructions {
上边距：15像素;
字体大小：0.8rem;
颜色：#95a5a6;
}

@媒体查询（最大宽度：768像素）{
    .mobile-controls {
        display: flex;
    }
    
    .instructions {
显示：无；
    }
}
